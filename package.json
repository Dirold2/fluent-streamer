{
  "name": "fluent-streamer",
  "version": "0.5.0",
  "description": "Fluent FFmpeg wrapper with real-time audio effects, timeout and progress tracking.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "ffmpeg",
    "typescript",
    "fluent",
    "video",
    "audio",
    "streaming"
  ],
  "author": "dirold2",
  "license": "MIT",
  "scripts": {
    "build": "tsc && esbuild 'dist/**/*.js' --outdir=dist --allow-overwrite --minify --sourcemap && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4"
  },
  "optionalDependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15"
  },
  "devDependencies": {
    "@dirold2/dev-tools": "^1.1.0",
    "@types/bun": "^1.3.14",
    "@types/deno": "^2.7.0",
    "@types/node": "^26.0.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
